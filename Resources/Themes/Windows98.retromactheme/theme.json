{
  "name": "Windows 98",
  "version": "1.0",
  "author": "RetroMac",
  "splashScreen": "splash.png",
  "splashFullscreen": true,
  "wallpaper": "wallpaper.jpg",
  "wallpapers": [
    {
      "name": "Clouds",
      "file": "wallpaper.jpg"
    },
    {
      "name": "Classic Teal",
      "file": "wallpaper-teal.png"
    }
  ],
  "dock": {
    "height": 40,
    "iconSize": 28,
    "padding": 4,
    "spacing": 4,
    "cornerRadius": 0,
    "backgroundColor": "#C4C4C4FF",
    "backgroundImage": null,
    "backgroundImageMode": "tile",
    "borderColor": "#000000FF",
    "borderWidth": 0,
    "shadowEnabled": false,
    "shadowColor": "#00000000",
    "shadowRadius": 0,
    "bevelTopColor": "#FFFFFFFF",
    "bevelBottomColor": "#808080FF",
    "bevelWidth": 2,
    "orientation": "horizontal",
    "position": "bottom",
    "fullWidth": true,
    "startButton": true,
    "startButtonLabel": "Start",
    "startButtonIcon": "start.png",
    "showClock": true
  },
  "icon": {
    "renderStyle": "pixelated",
    "reflectionEnabled": false,
    "reflectionOpacity": 0,
    "hoverScale": 1.05,
    "hoverAnimationDuration": 0.05
  },
  "indicator": {
    "style": "square",
    "color": "#000080",
    "size": 4,
    "offset": 3
  },
  "fallbackIcon": "generic.png",
  "defaultPreset": "crt-lite",
  "iconMappings": {
    "com.apple.finder": "finder.png",
    "com.apple.Safari": "safari.png",
    "com.apple.mail": "mail.png",
    "com.apple.Photos": "photos.png",
    "com.apple.MobileSMS": "messages.png",
    "com.apple.Notes": "notes.png",
    "com.apple.iCal": "calendar.png",
    "com.apple.systempreferences": "settings.png",
    "com.apple.Music": "music.png",
    "com.apple.Terminal": "terminal.png",
    "com.apple.AppStore": "appstore.png",
    "com.apple.Preview": "preview.png",
    "com.apple.TextEdit": "textedit.png",
    "com.apple.calculator": "calculator.png",
    "com.apple.Maps": "maps.png",
    "com.apple.AddressBook": "contacts.png",
    "com.apple.reminders": "reminders.png",
    "com.apple.iBooksX": "books.png",
    "com.apple.ActivityMonitor": "activitymonitor.png",
    "com.apple.archiveutility": "archive.png",
    "com.apple.dt.Xcode": "xcode.png",
    "com.microsoft.Word": "word.png",
    "com.microsoft.Excel": "excel.png",
    "com.microsoft.Powerpoint": "powerpoint.png",
    "org.mozilla.firefox": "firefox.png",
    "com.google.Chrome": "chrome.png",
    "org.gimp.gimp": "gimp.png",
    "org.videolan.vlc": "vlc.png",
    "com.apple.FaceTime": "facetime.png",
    "com.apple.clock": "clock.png",
    "com.apple.podcasts": "podcasts.png"
  },
  "desktopIcons": [
    {
      "name": "My Computer",
      "icon": "computer.png",
      "type": "folder",
      "path": "/",
      "gridX": 0,
      "gridY": 0
    },
    {
      "name": "My Documents",
      "icon": "documents.png",
      "type": "folder",
      "path": "~/Documents",
      "gridX": 0,
      "gridY": 1
    },
    {
      "name": "Programs",
      "icon": "programsfolder.png",
      "type": "appfolder",
      "gridX": 0,
      "gridY": 2
    },
    {
      "name": "Internet Explorer",
      "icon": "ie.png",
      "type": "webapp",
      "url": "https://www.yahoo.com",
      "args": [
        "1020",
        "740"
      ],
      "gridX": 0,
      "gridY": 3
    },
    {
      "name": "Notepad",
      "icon": "notepad98.png",
      "type": "webapp",
      "url": "https://bored-entertainment.github.io/98.js/programs/notepad/index.html",
      "args": [
        "660",
        "500"
      ],
      "gridX": 0,
      "gridY": 4
    },
    {
      "name": "Paint",
      "icon": "paint98.png",
      "type": "webapp",
      "url": "https://bored-entertainment.github.io/98.js/programs/jspaint/index.html",
      "args": [
        "920",
        "640"
      ],
      "gridX": 0,
      "gridY": 5
    },
    {
      "name": "Minesweeper",
      "icon": "mines.png",
      "type": "webapp",
      "url": "https://bored-entertainment.github.io/98.js/programs/minesweeper/index.html",
      "args": [
        "360",
        "460"
      ],
      "gridX": 0,
      "gridY": 6
    },
    {
      "name": "Solitaire",
      "icon": "solitaire.png",
      "type": "webapp",
      "url": "https://bored-entertainment.github.io/98.js/programs/js-solitaire/index.html",
      "args": [
        "800",
        "600"
      ],
      "gridX": 0,
      "gridY": 7
    },
    {
      "name": "CPU Monitor",
      "icon": "menu-sysguard.png",
      "type": "cpumonitor",
      "gridX": 1,
      "gridY": 0
    },
    {
      "name": "Clock",
      "icon": "clock.png",
      "type": "clock",
      "gridX": 1,
      "gridY": 1
    },
    {
      "name": "sheep.exe",
      "icon": "sheep.png",
      "type": "sheep",
      "gridX": 1,
      "gridY": 2
    },
    {
      "name": "Recycle Bin",
      "icon": "trash.png",
      "iconFull": "trash_full.png",
      "type": "trash",
      "gridX": 1,
      "gridY": 3
    }
  ],
  "desktopIconSize": 40
}
