{
  "name": "Sleek Retro",
  "version": "1.0",
  "author": "Aman Chokshi",
  "dock": {
    "height": 80,
    "iconSize": 56,
    "padding": 14,
    "spacing": 8,
    "cornerRadius": 16,
    "backgroundColor": "#1A1A2ECC",
