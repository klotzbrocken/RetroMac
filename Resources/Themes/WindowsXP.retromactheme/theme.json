{
  "name": "Windows XP",
  "version": "1.0",
  "author": "RetroMac",
  "splashScreen": "splash.png",
  "splashFullscreen": true,
  "wallpaper": "wallpaper.jpg",
  "wallpapers": [
    {
      "name": "Bliss",
      "file": "wallpaper.jpg"
    },
    {
      "name": "Azul",
      "file": "wallpaper2.png"
    },
    {
      "name": "XP Professional",
      "file": "xp-professional-wallpaper.jpg"
    }
  ],
  "dock": {
    "height": 44,
    "iconSize": 32,
    "padding": 6,
    "spacing": 4,
    "cornerRadius": 0,
    "backgroundColor": "#1856CDFF",
    "backgroundGradientTop": "#3168D5",
    "backgroundGradientBottom": "#1042A8",
    "backgroundImage": null,
    "backgroundImageMode": "tile",
    "borderColor": "#0C3B94FF",
    "borderWidth": 1,
    "shadowEnabled": false,
    "shadowColor": "#00000000",
    "shadowRadius": 0,
    "bevelTopColor": "#3C7DFFFF",
    "bevelBottomColor": "#0A246AFF",
    "bevelWidth": 1,
    "orientation": "horizontal",
    "position": "bottom",
    "fullWidth": true,
    "startButton": true,
    "startButtonLabel": "start",
    "startButtonIcon": "startxpblue.png",
    "startButtonImage": "startxpbluebutton.png",
    "startButtonColor": "#40AE2A",
    "startButtonGradientTop": "#52BD38",
    "startButtonGradientBottom": "#2D8E1B",
    "showClock": true,
    "magnification": false,
    "showTrash": false,
    "startMenuStyle": "xp"
  },
  "icon": {
    "renderStyle": "smooth",
    "reflectionEnabled": false,
    "reflectionOpacity": 0,
    "hoverScale": 1.05,
    "hoverAnimationDuration": 0.08
  },
  "indicator": {
    "style": "highlight",
    "color": "#5B9BD5",
    "size": 3,
    "offset": 2
  },
  "desktopIcons": [
    {
      "name": "My Computer",
      "icon": "xp_mycomputer.png",
      "type": "folder",
      "path": "/",
      "gridX": 0,
      "gridY": 0
    },
    {
      "name": "All Programs",
      "icon": "xp_documents.png",
      "type": "appfolder",
      "gridX": 0,
      "gridY": 1
    },
    {
      "name": "Recycle Bin",
      "icon": "recycle_empty.png",
      "iconFull": "recycle_full.png",
      "type": "trash",
      "gridX": 0,
      "gridY": 2
    },
    {
      "name": "CPU",
      "icon": "proz_xp.png",
      "type": "cpumonitor",
      "gridX": 0,
      "gridY": 3
    },
    {
      "name": "Internet Explorer",
      "icon": "safari.png",
      "type": "webapp",
      "url": "https://bored-entertainment.github.io/98.js/programs/explorer/index.html?address=https%3A%2F%2Fwww.amazon.com",
      "args": [
        "1020",
        "740"
      ],
      "gridX": 0,
      "gridY": 4
    },
    {
      "name": "Notepad",
      "icon": "notepad98.png",
      "type": "webapp",
      "url": "https://bored-entertainment.github.io/98.js/programs/notepad/index.html",
      "args": [
        "660",
        "500"
      ],
      "gridX": 0,
      "gridY": 5
    },
    {
      "name": "Paint",
      "icon": "paint98.png",
      "type": "webapp",
      "url": "https://bored-entertainment.github.io/98.js/programs/jspaint/index.html",
      "args": [
        "920",
        "640"
      ],
      "gridX": 0,
      "gridY": 6
    },
    {
      "name": "Minesweeper",
      "icon": "mines.png",
      "type": "webapp",
      "url": "https://bored-entertainment.github.io/98.js/programs/minesweeper/index.html",
      "args": [
        "360",
        "460"
      ],
      "gridX": 1,
      "gridY": 0
    },
    {
      "name": "Solitaire",
      "icon": "solitaire.png",
      "type": "webapp",
      "url": "https://bored-entertainment.github.io/98.js/programs/js-solitaire/index.html",
      "args": [
        "800",
        "600"
      ],
      "gridX": 1,
      "gridY": 1
    },
    {
      "name": "3D Pinball",
      "icon": "pinball.png",
      "type": "webapp",
      "url": "https://bored-entertainment.github.io/98.js/programs/pinball/space-cadet.html",
      "args": [
        "640",
        "620"
      ],
      "gridX": 1,
      "gridY": 2
    },
    {
      "name": "sheep.exe",
      "icon": "sheep.png",
      "type": "sheep",
      "gridX": 1,
      "gridY": 3
    }
  ],
  "fallbackIcon": "generic.png",
  "defaultPreset": "lcd-retro-lite",
  "iconMappings": {
    "com.apple.finder": "finder.png",
    "com.apple.Safari": "safari.png",
    "com.apple.mail": "mail.png",
    "com.apple.Photos": "photos.png",
    "com.apple.MobileSMS": "messages.png",
    "com.apple.Notes": "notes.png",
    "com.apple.iCal": "calendar.png",
    "com.apple.systempreferences": "settings.png",
    "com.apple.Music": "music.png",
    "com.apple.Terminal": "terminal.png"
  },
  "desktopIconSize": 48
}
