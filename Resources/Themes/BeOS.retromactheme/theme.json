{
  "name": "BeOS",
  "version": "1.0",
  "author": "RetroMac",
  "wallpaper": "wallpaper.jpg",
  "dock": {
    "height": 56,
    "iconSize": 40,
    "padding": 6,
    "spacing": 6,
    "cornerRadius": 0,
    "backgroundColor": "#D8D8D8FF",
    "backgroundImage": null,
    "backgroundImageMode": "tile",
    "borderColor": "#404040FF",
    "borderWidth": 1,
    "shadowEnabled": false,
    "shadowColor": "#00000000",
    "shadowRadius": 0,
    "bevelTopColor": "#FFFFFFFF",
    "bevelBottomColor": "#808080FF",
    "bevelWidth": 1,
    "orientation": "horizontal",
    "position": "bottom",
    "fullWidth": false,
    "startButton": false,
    "showClock": false,
    "magnification": false,
    "showTrash": true,
    "showGrip": true,
    "alignment": "left",
    "edgeOffset": 4
  },
  "icon": {
    "renderStyle": "smooth",
    "reflectionEnabled": false,
    "reflectionOpacity": 0,
    "hoverScale": 1.08,
    "hoverAnimationDuration": 0.1
  },
  "indicator": {
    "style": "dot",
    "color": "#3060C0",
    "size": 4,
    "offset": 3
  },
  "desktopIcons": [
    { "name": "Boot Disk", "icon": "finder.png", "type": "folder", "path": "/", "gridX": 0, "gridY": 1 },
    { "name": "Trash", "icon": "trash.png", "iconFull": "trash_full.png", "type": "trash", "gridX": 0, "gridY": 5 }
  ],
  "fallbackIcon": "generic.png",
  "defaultPreset": "lcd-retro-lite",
  "iconMappings": {
    "com.apple.finder": "finder.png",
    "com.apple.Safari": "safari.png",
    "com.apple.mail": "mail.png",
    "com.apple.Photos": "photos.png",
    "com.apple.MobileSMS": "messages.png",
    "com.apple.Notes": "notes.png",
    "com.apple.iCal": "calendar.png",
    "com.apple.systempreferences": "settings.png",
    "com.apple.Music": "music.png",
    "com.apple.Terminal": "terminal.png",
    "__trash__": "trash.png",
    "__trash_full__": "trash_full.png"
  }
}
