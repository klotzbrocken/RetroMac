{
  "name": "Mac OS 9.2",
  "version": "1.0",
  "author": "RetroMac",
  "dock": {
    "height": 52,
    "iconSize": 32,
    "padding": 10,
    "spacing": 6,
    "cornerRadius": 0,
    "backgroundColor": "#CCCCCCFF",
    "backgroundImage": null,
    "backgroundImageMode": "tile",
    "borderColor": "#000000FF",
    "borderWidth": 1,
    "shadowEnabled": false,
    "shadowColor": "#00000000",
    "shadowRadius": 0,
    "bevelTopColor": "#FFFFFFFF",
    "bevelBottomColor": "#888888FF",
    "bevelWidth": 2,
    "orientation": "horizontal",
    "position": "bottom",
    "alignment": "left"
  },
  "icon": {
    "renderStyle": "pixelated",
    "reflectionEnabled": false,
    "reflectionOpacity": 0,
    "hoverScale": 1.08,
    "hoverAnimationDuration": 0.05
  },
  "indicator": {
    "style": "square",
    "color": "#000000",
    "size": 4,
    "offset": 6
  },
  "wallpaper": "wallpaper.jpg",
  "fallbackIcon": "generic.png",
  "defaultPreset": "mac-classic",
  "iconMappings": {
    "com.apple.finder": "finder.png",
    "com.apple.Safari": "safari.png",
    "com.apple.mail": "mail.png",
    "com.apple.Photos": "photos.png",
    "com.apple.MobileSMS": "messages.png",
    "com.apple.Notes": "notes.png",
    "com.apple.iCal": "calendar.png",
    "com.apple.systempreferences": "settings.png",
    "com.apple.Music": "music.png",
    "com.apple.Terminal": "terminal.png",
    "com.apple.TextEdit": "textedit.png",
    "com.apple.QuickTimePlayerX": "quicktime.png",
    "com.apple.DiskUtility": "diskutility.png",
    "com.apple.garageband": "garageband.png",
    "com.apple.iMovieApp": "imovie.png",
    "com.apple.Dictionary": "dictionary.png",
    "com.apple.reminders": "reminders.png"
  },
  "screensaver": "flying-toasters",
  "appearance": "light",
  "accentColor": "graphite"
}
