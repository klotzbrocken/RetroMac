{
  "name": "Mac OS X",
  "version": "1.0",
  "author": "RetroMac",
  "dock": {
    "height": 80,
    "iconSize": 66,
    "padding": 7,
    "spacing": 5,
    "cornerRadius": 6,
    "edgeOffset": 6,
    "backgroundColor": "#6E92CE96",
    "backgroundGradientTop": "#A8C6EEA0",
    "backgroundGradientBottom": "#5C82BEAA",
    "shelfLineColor": null,
    "backgroundImage": null,
    "backgroundImageMode": "tile",
    "borderColor": "#DCEAFBCC",
    "borderWidth": 1,
    "shadowEnabled": true,
    "shadowColor": "#00000055",
    "shadowRadius": 16,
    "bevelTopColor": "#FFFFFFAA",
    "bevelBottomColor": "#3F619EAA",
    "bevelWidth": 1.5,
    "pinstripe": true,
    "shelfStyle": "flat",
    "magnification": true,
    "magnificationScale": 2.0,
    "showTrash": true,
    "showUrlLauncher": true,
    "showLabels": true
  },
  "magnification": {
    "enabled": true,
    "scale": 2.0
  },
  "icon": {
    "renderStyle": "smooth",
    "reflectionEnabled": false,
    "reflectionOpacity": 0.0,
    "hoverScale": 1.2,
    "hoverAnimationDuration": 0.15
  },
  "indicator": {
    "style": "triangle",
    "color": "#000000",
    "size": 7,
    "offset": 9
  },
  "wallpaper": "wallpaper.jpg",
  "fallbackIcon": "generic.png",
  "defaultPreset": "lcd-retro-lite",
  "desktopIcons": [
    { "name": "Macintosh HD", "icon": "harddisk.png", "type": "folder", "path": "/", "gridX": 0, "gridY": 0 },
    { "name": "Applications", "icon": "applications.png", "type": "appfolder", "gridX": 0, "gridY": 1 },
    { "name": "Clock", "icon": "clock.png", "type": "clock", "gridX": 0, "gridY": 2 },
    { "name": "CPU Monitor", "icon": "cpuwidget.png", "type": "cpumonitor", "gridX": 0, "gridY": 3 },
    { "name": "Notepad", "icon": "notepad.png", "type": "notepad", "gridX": 0, "gridY": 4 },
    { "name": "Sherlock", "icon": "sherlock.png", "type": "url", "url": "https://www.google.com", "gridX": 0, "gridY": 5 }
  ],
  "iconMappings": {
    "com.apple.finder": "finder.png",
    "com.apple.Safari": "safari.png",
    "com.apple.mail": "mail.png",
    "com.apple.Photos": "photos.png",
    "com.apple.MobileSMS": "messages.png",
    "com.apple.Notes": "notes.png",
    "com.apple.iCal": "calendar.png",
    "com.apple.systempreferences": "systempreferences.png",
    "com.apple.Terminal": "terminal.png",
    "com.apple.Music": "itunes.png",
    "com.apple.iTunes": "itunes.png",
    "com.apple.AppStore": "appstore.png",
    "com.apple.FaceTime": "facetime.png",
    "com.apple.AddressBook": "contacts.png",
    "com.apple.reminders": "reminders.png",
    "com.apple.Preview": "preview_app.png",
    "com.apple.TextEdit": "textedit.png",
    "com.apple.calculator": "calculator.png",
    "com.apple.Dictionary": "dictionary.png",
    "com.apple.QuickTimePlayerX": "quicktime.png",
    "com.apple.DiskUtility": "diskutility.png",
    "com.apple.ActivityMonitor": "activitymonitor.png",
    "com.apple.Console": "console.png",
    "com.apple.iMovieApp": "imovie.png",
    "com.apple.Automator": "automator.png",
    "com.apple.FontBook": "fontbook.png",
    "com.apple.Chess": "chess.png",
    "com.apple.Stickies": "stickies.png",
    "com.apple.PhotoBooth": "photobooth.png",
    "com.apple.Image_Capture": "imagecapture.png",
    "com.apple.grapher": "grapher.png",
    "com.apple.DVDPlayer": "dvdplayer.png",
    "com.apple.keychainaccess": "keychain.png",
    "com.apple.clock": "clock.png"
  }
}
