{
  "name": "OS/2 Warp 4",
  "version": "1.2",
  "author": "RetroMac",
  "wallpaper": "wallpaper.png",
  "dock": {
    "height": 34,
    "iconSize": 24,
    "padding": 4,
    "spacing": 4,
    "cornerRadius": 0,
    "backgroundColor": "#C9C9C9FF",
    "backgroundImage": null,
    "backgroundImageMode": "tile",
    "borderColor": "#000000FF",
    "borderWidth": 0,
    "shadowEnabled": false,
    "shadowColor": "#00000000",
    "shadowRadius": 0,
    "bevelTopColor": "#FFFFFFFF",
    "bevelBottomColor": "#808080FF",
    "bevelWidth": 1,
    "orientation": "horizontal",
    "position": "bottom",
    "fullWidth": true,
    "startButton": true,
    "startButtonLabel": "OS/2",
    "startButtonIcon": "start.png",
    "showClock": true,
    "magnification": false,
    "showTrash": false,
    "startMenuStyle": "classic",
    "startButtonStyle": "sunken",
    "startButtonImage": "os2warp_startbutton.png",
    "clockFormat": "hh:mm:ss a",
    "clockFontSize": 11,
    "showDiskFree": true
  },
  "icon": {
    "renderStyle": "pixelated",
    "reflectionEnabled": false,
    "reflectionOpacity": 0,
    "hoverScale": 1.08,
    "hoverAnimationDuration": 0.05
  },
  "indicator": {
    "style": "square",
    "color": "#000080",
    "size": 4,
    "offset": 2
  },
  "fallbackIcon": "generic.png",
  "defaultPreset": "crt-royale-lite",
  "iconMappings": {
    "com.apple.finder": "finder.png",
    "com.apple.Safari": "safari.png",
    "com.apple.mail": "mail.png",
    "com.apple.Photos": "photos.png",
    "com.apple.MobileSMS": "messages.png",
    "com.apple.Notes": "notes.png",
    "com.apple.iCal": "calendar.png",
    "com.apple.systempreferences": "settings.png",
    "com.apple.Music": "music.png",
    "com.apple.Terminal": "terminal.png"
  }
}
