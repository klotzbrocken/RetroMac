{
  "name": "Windows 3.1",
  "version": "1.0",
  "author": "RetroMac",
  "wallpaper": "wallpaper-teal.png",
  "splashScreen": "splash.png",
  "wallpapers": [
    { "name": "Teal (Default)", "file": "wallpaper-teal.png" },
    { "name": "50% Gray", "file": "wallpaper-gray50.png" },
    { "name": "Boxes", "file": "wallpaper-boxes.png" },
    { "name": "Diamonds", "file": "wallpaper-diamonds.png" },
    { "name": "Paisley", "file": "wallpaper-paisley.png" },
    { "name": "Quilt", "file": "wallpaper-quilt.png" },
    { "name": "Scottie", "file": "wallpaper-scottie.png" },
    { "name": "Thatch", "file": "wallpaper-thatch.png" },
    { "name": "Tulip", "file": "wallpaper-tulip.png" },
    { "name": "Waffle", "file": "wallpaper-waffle.png" },
    { "name": "Weave", "file": "wallpaper-weave.png" }
  ],
  "dock": {
    "height": 40,
    "iconSize": 28,
    "padding": 4,
    "spacing": 4,
    "cornerRadius": 0,
    "backgroundColor": "#C0C0C0FF",
    "backgroundImage": null,
    "backgroundImageMode": "tile",
    "borderColor": "#000000FF",
    "borderWidth": 0,
    "shadowEnabled": false,
    "shadowColor": "#00000000",
    "shadowRadius": 0,
    "bevelTopColor": "#FFFFFFFF",
    "bevelBottomColor": "#808080FF",
    "bevelWidth": 2,
    "orientation": "horizontal",
    "position": "bottom",
    "dockStyle": "none"
  },
  "icon": {
    "renderStyle": "pixelated",
    "reflectionEnabled": false,
    "reflectionOpacity": 0,
    "hoverScale": 1.0,
    "hoverAnimationDuration": 0.05
  },
  "indicator": {
    "style": "none",
    "color": "#000080",
    "size": 0,
    "offset": 0
  },
  "fallbackIcon": "group.png",
  "defaultPreset": "lcd-sharp-lite",
  "iconMappings": {
    "com.apple.finder": "filemanager.png",
    "com.apple.systempreferences": "controlpanel.png",
    "com.apple.Terminal": "msdos.png",
    "com.apple.TextEdit": "write.png",
    "com.apple.Notes": "notepad.png",
    "com.apple.Stickies": "notepad.png",
    "com.apple.Preview": "paintbrush.png",
    "com.apple.calculator": "calculator.png",
    "com.apple.iCal": "calendar.png",
    "com.apple.AddressBook": "cardfile.png",
    "com.apple.clock": "clock.png",
    "com.apple.FontBook": "charmap.png",
    "com.apple.Music": "mediaplayer.png",
    "com.apple.VoiceMemos": "recorder.png",
    "com.apple.Safari": "app1.png",
    "com.apple.mail": "mail.png",
    "com.apple.Photos": "app2.png",
    "com.apple.MobileSMS": "app3.png",
    "com.apple.Chess": "solitaire.png"
  },
  "programManager": {
    "title": "Program Manager",
    "groups": [
      {
        "name": "Main",
