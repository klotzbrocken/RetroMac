 static bool dummyRenderer = false;
 
+// ---------------------------------------------------------------------------
+// RetroMac themed window chrome
+//
+// RetroMac hosts this engine and hands its active theme over in RETROMAC_THEME. With a
+// theme active we drop the OS title bar (borderless window), grow the window by a title
+// strip plus a border, and paint that strip ourselves so the game sits in the same window
+// frame as the rest of the desktop — the trick the bundled Pac-Man demo already uses.
+//
+// The strip carries no title text on purpose: this engine links no text renderer (SDL_ttf
+// is not among its third-party libraries), and its own bitmap fonts draw into the game
+// surface, not into the chrome.
+//
+// Windowed only. Fullscreen keeps the plain borderless-desktop window it always had.
+// ---------------------------------------------------------------------------
+enum RetroMacTheme { RM_NONE = 0, RM_BEOS, RM_MACOS9, RM_WINXP, RM_MACOS6 };
+static RetroMacTheme rmTheme = RM_NONE;
+static SDL_Rect rmClose  = {0, 0, 0, 0};
+
+// Shared with video.cpp: ResizeScreen has to include the chrome in the renderer's logical
+// size, otherwise every draw here is interpreted in the game's 640x480 space and the strip
+// lands inside the scaled picture instead of above it.
+bool RetroMacChromeActive = false;   // chrome is being drawn (theme set + windowed)
+int  RetroMacChromeTitleH = 0;       // height of the title strip
+int  RetroMacChromeBorder = 0;       // side/bottom frame width
+#define rmThemed RetroMacChromeActive
+#define rmTitleH RetroMacChromeTitleH
+#define rmBorder RetroMacChromeBorder
+
+/// Pick the chrome metrics for the host's theme. Unknown/absent theme → no chrome, so a
+/// standalone run (or RetroMac's "default" theme) keeps an ordinary OS window.
+static void RetroMacInitChrome(bool fullscreen)
+{
+	rmTheme = RM_NONE; rmThemed = false; rmTitleH = 0; rmBorder = 0;
+	const char *th = getenv("RETROMAC_THEME");
+	if (!th || !*th || fullscreen) {
+		return;
+	}
+	if (!strcmp(th, "beos"))          { rmTheme = RM_BEOS;   rmBorder = 4; rmTitleH = 26; rmClose = {8, 7, 14, 14}; }
+	else if (!strcmp(th, "macos9"))   { rmTheme = RM_MACOS9; rmBorder = 2; rmTitleH = 22; rmClose = {8, 5, 13, 13}; }
+	else if (!strcmp(th, "macos6"))   { rmTheme = RM_MACOS6; rmBorder = 2; rmTitleH = 22; rmClose = {8, 5, 13, 13}; }
+	else if (!strcmp(th, "winxp"))    { rmTheme = RM_WINXP;  rmBorder = 4; rmTitleH = 30; rmClose = {0, 0, 21, 21}; }
+	else                              { return; }
+	rmThemed = true;
+}
+
+/// Window coords → game-area coords. The chrome shifts the picture right and down, so every
+/// mouse position the host OS reports has to be pulled back before the game sees it.
+static inline void RetroMacUnoffsetMouse(int &x, int &y)
+{
+	if (!rmThemed) { return; }
+	x -= rmBorder;
+	y -= rmTitleH;
+}
+
+static inline bool RetroMacInRect(const SDL_Rect &r, int x, int y)
+{
+	return x >= r.x && x < r.x + r.w && y >= r.y && y < r.y + r.h;
+}
+
+/// The title strip drags the window; the close box doesn't (it's a button).
+static SDL_HitTestResult SDLCALL RetroMacHitTest(SDL_Window *, const SDL_Point *p, void *)
+{
+	if (p->y < rmTitleH && !RetroMacInRect(rmClose, p->x, p->y)) {
+		return SDL_HITTEST_DRAGGABLE;
+	}
+	return SDL_HITTEST_NORMAL;
+}
+
+/// Close box → quit, before the click can reach the game.
+static int SDLCALL RetroMacEventWatch(void *, SDL_Event *e)
+{
+	if (rmThemed && e->type == SDL_MOUSEBUTTONDOWN && e->button.button == SDL_BUTTON_LEFT
+	    && RetroMacInRect(rmClose, e->button.x, e->button.y)) {
+		SDL_Event q; q.type = SDL_QUIT; SDL_PushEvent(&q);
+	}
+	return 1;
+}
+
+static inline void RetroMacFill(SDL_Renderer *r, int x, int y, int w, int h,
+                                Uint8 cr, Uint8 cg, Uint8 cb)
+{
+	SDL_Rect rect = {x, y, w, h};
+	SDL_SetRenderDrawColor(r, cr, cg, cb, 255);
+	SDL_RenderFillRect(r, &rect);
+}
+
+/// Paint the frame around the game picture. Called every present, because the renderer is
+/// cleared each frame — the same reason the Pac-Man demo repaints its chrome per frame.
+static void RetroMacDrawChrome(SDL_Renderer *r, int winW, int winH)
+{
+	if (!rmThemed) { return; }
+	const int T = rmTitleH;
+
+	switch (rmTheme) {
+	case RM_BEOS: {
+		RetroMacFill(r, 0, 0, winW, winH, 0xD6, 0xD6, 0xD6);              // grey frame
+		RetroMacFill(r, 0, 0, winW, 1, 0xFF, 0xFF, 0xFF);                 // raised bevel
+		RetroMacFill(r, 0, 0, 1, winH, 0xFF, 0xFF, 0xFF);
+		RetroMacFill(r, 0, winH - 1, winW, 1, 0x8A, 0x8A, 0x8A);
+		RetroMacFill(r, winW - 1, 0, 1, winH, 0x8A, 0x8A, 0x8A);
+		const int tabW = 150;                                             // yellow Lasche
+		RetroMacFill(r, 0, 0, tabW, T, 0xFB, 0xD8, 0x5C);
+		RetroMacFill(r, 0, T / 2, tabW, T / 2, 0xF2, 0xBD, 0x23);
+		RetroMacFill(r, 0, 0, tabW, 1, 0x2A, 0x2A, 0x2A);
+		RetroMacFill(r, 0, 0, 1, T, 0x2A, 0x2A, 0x2A);
+		RetroMacFill(r, tabW - 1, 0, 1, T, 0x2A, 0x2A, 0x2A);
+		RetroMacFill(r, tabW, T - 1, winW - tabW, 1, 0x2A, 0x2A, 0x2A);
+		RetroMacFill(r, rmClose.x, rmClose.y, rmClose.w, rmClose.h, 0xEA, 0xB9, 0x2A);
+		RetroMacFill(r, rmClose.x, rmClose.y, rmClose.w, 1, 0x2A, 0x2A, 0x2A);
+		RetroMacFill(r, rmClose.x, rmClose.y, 1, rmClose.h, 0x2A, 0x2A, 0x2A);
+		RetroMacFill(r, rmClose.x, rmClose.y + rmClose.h - 1, rmClose.w, 1, 0x2A, 0x2A, 0x2A);
+		RetroMacFill(r, rmClose.x + rmClose.w - 1, rmClose.y, 1, rmClose.h, 0x2A, 0x2A, 0x2A);
+		break;
+	}
+	case RM_MACOS9: {
+		RetroMacFill(r, 0, 0, winW, winH, 0xD8, 0xD8, 0xD8);              // platinum face
+		for (int y = 1; y < T - 1; y += 2) {                              // pinstripes
+			RetroMacFill(r, 1, y, winW - 2, 1, 0xED, 0xED, 0xED);
+			RetroMacFill(r, 1, y + 1, winW - 2, 1, 0xBD, 0xBD, 0xBD);
+		}
+		RetroMacFill(r, 0, 0, winW, 1, 0, 0, 0);                          // black window frame
+		RetroMacFill(r, 0, 0, 1, winH, 0, 0, 0);
+		RetroMacFill(r, 0, winH - 1, winW, 1, 0, 0, 0);
+		RetroMacFill(r, winW - 1, 0, 1, winH, 0, 0, 0);
+		RetroMacFill(r, 0, T - 1, winW, 1, 0x80, 0x80, 0x80);             // bar separator
+		RetroMacFill(r, rmClose.x, rmClose.y, rmClose.w, rmClose.h, 0xD8, 0xD8, 0xD8);
+		RetroMacFill(r, rmClose.x, rmClose.y, rmClose.w, 1, 0xFF, 0xFF, 0xFF);
+		RetroMacFill(r, rmClose.x, rmClose.y, 1, rmClose.h, 0xFF, 0xFF, 0xFF);
+		RetroMacFill(r, rmClose.x, rmClose.y + rmClose.h - 1, rmClose.w, 1, 0x80, 0x80, 0x80);
+		RetroMacFill(r, rmClose.x + rmClose.w - 1, rmClose.y, 1, rmClose.h, 0x80, 0x80, 0x80);
+		break;
+	}
+	case RM_MACOS6: {
+		RetroMacFill(r, 0, 0, winW, winH, 0xFF, 0xFF, 0xFF);              // 1-bit white
+		for (int y = 3; y <= T - 5; y += 2) {                             // racing stripes
+			RetroMacFill(r, 6, y, winW - 12, 1, 0, 0, 0);
+		}
+		RetroMacFill(r, 0, 0, winW, 1, 0, 0, 0);                          // black frame
+		RetroMacFill(r, 0, 0, 1, winH, 0, 0, 0);
+		RetroMacFill(r, 0, winH - 1, winW, 1, 0, 0, 0);
+		RetroMacFill(r, winW - 1, 0, 1, winH, 0, 0, 0);
+		RetroMacFill(r, 0, T - 1, winW, 1, 0, 0, 0);
+		RetroMacFill(r, rmClose.x, rmClose.y, rmClose.w, rmClose.h, 0xFF, 0xFF, 0xFF);
+		RetroMacFill(r, rmClose.x, rmClose.y, rmClose.w, 1, 0, 0, 0);     // hollow close box
+		RetroMacFill(r, rmClose.x, rmClose.y, 1, rmClose.h, 0, 0, 0);
+		RetroMacFill(r, rmClose.x, rmClose.y + rmClose.h - 1, rmClose.w, 1, 0, 0, 0);
+		RetroMacFill(r, rmClose.x + rmClose.w - 1, rmClose.y, 1, rmClose.h, 0, 0, 0);
+		break;
+	}
+	case RM_WINXP: {
+		RetroMacFill(r, 0, 0, winW, winH, 0x08, 0x31, 0xD9);              // Luna blue frame
+		for (int y = 0; y < T; y++) {                                     // title gradient
+			const double t = (double)y / (T - 1);
+			Uint8 cr, cg, cb;
+			if (t < 0.5) { const double u = t / 0.5;
+				cr = (Uint8)(0x09 + u * (0x00 - 0x09));
+				cg = (Uint8)(0x97 + u * (0x53 - 0x97));
+				cb = (Uint8)(0xFF + u * (0xEE - 0xFF)); }
+			else { const double u = (t - 0.5) / 0.5;
+				cr = 0x00;
+				cg = (Uint8)(0x66 + u * (0x3D - 0x66));
+				cb = (Uint8)(0xFF + u * (0xD2 - 0xFF)); }
+			RetroMacFill(r, 0, y, winW, 1, cr, cg, cb);
+		}
+		rmClose.x = winW - 4 - 23; rmClose.y = (T - 21) / 2; rmClose.w = 23; rmClose.h = 21;
+		RetroMacFill(r, rmClose.x, rmClose.y, rmClose.w, rmClose.h, 0xD0, 0x3A, 0x29);
+		RetroMacFill(r, rmClose.x, rmClose.y, rmClose.w, 1, 0xFF, 0xFF, 0xFF);
+		RetroMacFill(r, rmClose.x, rmClose.y, 1, rmClose.h, 0xFF, 0xFF, 0xFF);
+		for (int i = 0; i < 9; i++) {                                     // close X
+			RetroMacFill(r, rmClose.x + 7 + i, rmClose.y + 6 + i, 2, 1, 0xFF, 0xFF, 0xFF);
+			RetroMacFill(r, rmClose.x + 7 + i, rmClose.y + rmClose.h - 7 - i, 2, 1, 0xFF, 0xFF, 0xFF);
+		}
+		break;
+	}
+	default: break;
+	}
+}
