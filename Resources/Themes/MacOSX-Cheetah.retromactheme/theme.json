    "bevelTopColor": "#FFFFFFAA",
    "bevelBottomColor": "#3F619EAA",
    "bevelWidth": 1.5,
    "pinstripe": true,
    "shelfStyle": "flat",
    "magnification": true,
    "magnificationScale": 2.0,
    "showTrash": true,
    "showUrlLauncher": true,
    "showLabels": true
