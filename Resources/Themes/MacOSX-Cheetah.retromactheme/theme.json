{
  "name": "Mac OS X",
  "systemTweaks": [
    { "domain": "-g", "key": "NSConvolutionOverride1", "type": "float", "value": "6", "refresh": "Finder" },
    { "domain": "-g", "key": "NSSplitViewItemGlassMinimumCornerRadius", "type": "float", "value": "6", "refresh": "Finder" },
    { "domain": "-g", "key": "AppleShowScrollBars", "type": "string", "value": "Always" },
    { "domain": "com.apple.finder", "key": "FXPreferredViewStyle", "type": "string", "value": "icnv", "refresh": "Finder" },
    { "domain": "com.apple.finder", "key": "ShowPathbar", "type": "bool", "value": "true", "refresh": "Finder" },
    { "domain": "com.apple.dock", "key": "mineffect", "type": "string", "value": "genie", "refresh": "Dock" }
  ],
  "menuBarApple": "aqua-classic",
  "version": "1.0",
  "author": "RetroMac",
  "dock": {
    "height": 63,
    "iconSize": 52,
    "padding": 7,
    "spacing": 5,
    "cornerRadius": 6,
    "edgeOffset": 6,
    "backgroundColor": "#6E92CE96",
    "backgroundGradientTop": "#A8C6EEA0",
    "backgroundGradientBottom": "#5C82BEAA",
    "shelfLineColor": null,
    "backgroundImage": null,
    "backgroundImageMode": "tile",
    "borderColor": "#DCEAFBCC",
    "borderWidth": 1,
    "shadowEnabled": true,
    "shadowColor": "#00000055",
