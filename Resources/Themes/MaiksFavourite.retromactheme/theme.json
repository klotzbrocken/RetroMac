{
  "name": "Maiks Favourite",
  "version": "1.0",
  "author": "Maik",
  "wallpaper": "wallpaper.png",
  "dock": {
    "height": 76,
    "iconSize": 56,
    "padding": 8,
    "spacing": 4,
    "cornerRadius": 10,
    "backgroundColor": "#0B0B16F2",
    "backgroundImage": null,
    "backgroundImageMode": "tile",
    "borderColor": "#161616FF",
    "borderWidth": 0,
    "borderStyle": "pacman",
    "windowPreview": true,
    "folderStacks": true,
    "shadowEnabled": false,
    "shadowColor": "#00000000",
    "shadowRadius": 0,
    "bevelTopColor": "#EAEAEAFF",
    "bevelBottomColor": "#6E6E6EFF",
    "bevelWidth": 0,
    "orientation": "horizontal",
    "position": "bottom",
    "fullWidth": false,
    "startButton": false,
    "showClock": false,
    "magnification": false,
    "showTrash": true,
    "showGrip": false,
    "alignment": "left",
    "edgeOffset": 0
  },
  "icon": {
    "renderStyle": "pixelated",
    "reflectionEnabled": false,
    "reflectionOpacity": 0,
    "hoverScale": 1.35,
    "hoverAnimationDuration": 0.12
  },
  "indicator": {
    "style": "square",
    "color": "#FFD800",
    "size": 4,
    "offset": 0
  },
  "desktopIcons": [
    {
      "name": "Trash",
      "icon": "trash.png",
      "iconFull": "trash_full.png",
      "type": "trash",
      "gridX": 0,
      "gridY": 0
    },
    {
      "name": "Applications",
      "icon": "finder.png",
      "type": "appfolder",
      "gridX": 0,
      "gridY": 1
    },
    {
      "name": "CPU",
      "icon": "Proz.icns",
      "type": "cpumonitor",
      "gridX": 0,
      "gridY": 2
    },
    {
      "name": "Music",
      "icon": "TVStreams.icns",
      "type": "tvfolder",
      "gridX": 0,
      "gridY": 3
    },
    {
      "name": "Clock",
      "icon": "clock.icns",
      "type": "clock",
      "gridX": 0,
      "gridY": 4
    },
    {
      "name": "Notepad",
      "icon": "notes.png",
      "type": "notepad",
      "gridX": 0,
      "gridY": 5
    }
  ],
  "fallbackIcon": "generic.png",
  "defaultPreset": "lcd-retro-lite",
  "iconMappings": {
    "com.apple.finder": "finder.png",
    "com.apple.Safari": "safari.png",
    "ai.perplexity.comet": "comet.icns",
    "com.apple.mail": "mail.png",
    "com.apple.Photos": "photos.png",
    "com.apple.MobileSMS": "messages.png",
    "com.apple.Notes": "notes.png",
    "com.apple.iCal": "calendar.png",
    "com.apple.reminders": "tasks.png",
    "com.apple.Terminal": "terminal.png",
    "com.apple.Music": "music.png",
    "com.apple.systempreferences": "settings.png",
    "__trash__": "trash.png",
    "__trash_full__": "trash_full.png"
  },
  "appearance": "light",
  "accentColor": "blue"
}
