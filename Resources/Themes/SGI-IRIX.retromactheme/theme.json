        { "title": "Web", "item": { "name": "Web", "icon": "display.png", "type": "app", "bundleID": "com.apple.Safari" } },
        { "title": "Mail", "item": { "name": "Mail", "icon": "calendar.png", "type": "app", "bundleID": "com.apple.mail" } },
        { "title": "Media", "item": { "name": "Media", "icon": "media.png", "type": "app", "bundleID": "com.apple.Music" } }
